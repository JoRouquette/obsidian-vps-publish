{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-config",
      "urls": ["/api/config", "/api/config/**", "/public-config"],
      "cacheConfig": {
        "maxSize": 5,
        "maxAge": "1h",
        "strategy": "freshness",
        "timeout": "5s"
      }
    },
    {
      "name": "manifest",
      "urls": ["/content/_manifest.json*"],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "7d",
        "strategy": "freshness",
        "timeout": "3s"
      }
    },
    {
      "name": "content-pages",
      "urls": ["/content/**/*.html*", "/content/**"],
      "cacheConfig": {
        "maxSize": 200,
        "maxAge": "30d",
        "strategy": "freshness",
        "timeout": "5s"
      }
    },
    {
      "name": "backend-assets",
      "urls": ["/assets/**"],
      "cacheConfig": {
        "maxSize": 500,
        "maxAge": "365d",
        "strategy": "freshness",
        "timeout": "10s"
      }
    },
    {
      "name": "search-index",
      "urls": ["/content/_search-index.json*"],
      "cacheConfig": {
        "maxSize": 5,
        "maxAge": "1h",
        "strategy": "freshness",
        "timeout": "3s"
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/**/*__*",
    "!/**/*__*/**",
    "!/api/**",
    "!/content/**",
    "!/assets/**",
    "!/events/**"
  ]
}
