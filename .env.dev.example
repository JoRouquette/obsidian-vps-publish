########################################
# .env.dev - configuration de developpement
# A copier depuis ce modele :
#   cp .env.dev.example .env.dev
########################################

# Runtime Node
NODE_ENV=development
PORT=3000

# Dossiers de developpement (chemins relatifs)
# Ces dossiers seront crees automatiquement dans le projet
# Note: pour Docker, le compose dev injecte ensuite des chemins absolus Linux.
CONTENT_ROOT=./tmp/site-content
ASSETS_ROOT=./tmp/assets
UI_ROOT=./dist/apps/site/browser
UI_SERVER_ROOT=./dist/apps/site/server

# SSR (Server-Side Rendering) - configuration de developpement
# IMPORTANT: Angular 20 a encore des soucis de compilation JIT en SSR.
# Recommande: garder SSR desactive en dev et l'activer seulement pour verification ciblee.
SSR_ENABLED=false

# Logging
LOGGER_LEVEL=debug
LOG_FILE_PATH=./tmp/logs/node.log

# Admin dashboard (path + scrypt hashes)
# Generate a hash with Bash/Git Bash:
# node -e 'const { scryptSync, randomBytes } = require("node:crypto"); const salt = randomBytes(16).toString("base64url"); const hash = scryptSync("CHANGE_ME", salt, 64).toString("base64url"); console.log("scrypt$" + salt + "$" + hash);'
# Generate a hash with PowerShell:
# node -e "const { scryptSync, randomBytes } = require('node:crypto'); const salt = randomBytes(16).toString('base64url'); const hash = scryptSync('CHANGE_ME', salt, 64).toString('base64url'); console.log('scrypt$' + salt + '$' + hash);"
# ADMIN_API_PATH=/admin-api
# ADMIN_USERNAME_HASH='scrypt$CHANGE_ME_SALT$CHANGE_ME_HASH'
# ADMIN_PASSWORD_HASH='scrypt$CHANGE_ME_SALT$CHANGE_ME_HASH'

# Performance tuning (optional, defaults applied if not set)
# MAX_ACTIVE_REQUESTS=200
# MAX_CONCURRENT_FINALIZATION_JOBS=8
# MAX_ASSET_SIZE_BYTES=52428800

# Asset security (optional, defaults applied if not set)
# VIRUS_SCANNER_ENABLED=false
# CLAMAV_HOST=localhost
# CLAMAV_PORT=3310
# CLAMAV_TIMEOUT=10000

# Image optimization (optional, enabled by default)
# IMAGE_OPTIMIZATION_ENABLED=true
# IMAGE_CONVERT_TO_WEBP=true
# IMAGE_QUALITY=85
# IMAGE_MAX_WIDTH=4096
# IMAGE_MAX_HEIGHT=4096

# CORS / front dev
ALLOWED_ORIGINS=*,app://obsidian,http://localhost:4200,http://localhost:3000

# SEO
SITE_NAME=Obsidian VPS Publish
HOME_WELCOME_TITLE=Bienvenue sur Obsidian VPS Publish
BASE_URL=http://localhost:3000

# Informations publiques
AUTHOR=Jonathan Rouquette
REPO_URL=https://github.com/JoRouquette/obsidian-vps-publish
REPORT_ISSUES_URL=https://github.com/JoRouquette/obsidian-vps-publish/issues

# Secret de dev
API_KEY=dev-api-key

# Nx configuration
NX_INTERACTIVE=false
CI=true
