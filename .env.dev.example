########################################
# .env.dev – config DEV locale
# À copier depuis ce modèle :
#   cp .env.dev.example .env.dev
########################################

# Env Node
NODE_ENV=development
PORT=3000

# Dossiers pour le développement local (chemins relatifs)
# Ces dossiers seront créés automatiquement dans le projet
# Note: Pour Docker, utilisez des chemins absolus comme /content, /assets, /ui
CONTENT_ROOT=./tmp/site-content
ASSETS_ROOT=./tmp/assets
UI_ROOT=./dist/apps/site/browser
UI_SERVER_ROOT=./dist/apps/site/server

MAX_ASSET_SIZE_BYTES=52428800  # 50MB

# SSR (Server-Side Rendering) - Local dev config
# ⚠️  IMPORTANT: Angular 20 SSR has known JIT compilation issues (PlatformLocation error)
# Recommended: Keep SSR disabled in dev until fixed, use "SSR: Full Restart" task for testing
SSR_ENABLED=false                  # Disable SSR for faster local dev (default: false in dev)
# UI_SERVER_ROOT=./dist/apps/site/server  # Path to Angular SSR server bundle (required if SSR_ENABLED=true)

# Logging & debug
LOGGER_LEVEL=debug
LOG_FILE_PATH=./node.log

# Admin dashboard (path + scrypt hashes)
# Generate a hash with Bash/Git Bash:
# node -e 'const { scryptSync, randomBytes } = require("node:crypto"); const salt = randomBytes(16).toString("base64url"); const hash = scryptSync("CHANGE_ME", salt, 64).toString("base64url"); console.log("scrypt$" + salt + "$" + hash);'
# Generate a hash with PowerShell:
# node -e "const { scryptSync, randomBytes } = require('node:crypto'); const salt = randomBytes(16).toString('base64url'); const hash = scryptSync('CHANGE_ME', salt, 64).toString('base64url'); console.log('scrypt$' + salt + '$' + hash);"
# ADMIN_API_PATH=/admin-api
# ADMIN_USERNAME_HASH='scrypt$CHANGE_ME_SALT$CHANGE_ME_HASH'
# ADMIN_PASSWORD_HASH='scrypt$CHANGE_ME_SALT$CHANGE_ME_HASH'

# Performance tuning (optional, defaults applied if not set)
# MAX_ACTIVE_REQUESTS=200            # Max concurrent HTTP requests (default: 200)
# MAX_CONCURRENT_FINALIZATION_JOBS=8 # Max parallel session finalization jobs (default: 8)

# Asset security (optional, defaults applied if not set)
# MAX_ASSET_SIZE_BYTES=10485760      # Max asset file size in bytes (default: 10MB = 10*1024*1024)
# VIRUS_SCANNER_ENABLED=false        # Enable ClamAV virus scanning (default: false, requires clamd daemon)
# CLAMAV_HOST=localhost              # ClamAV daemon host (default: localhost)
# CLAMAV_PORT=3310                   # ClamAV daemon port (default: 3310)
# CLAMAV_TIMEOUT=10000               # ClamAV scan timeout in ms (default: 10000)

# Image optimization (optional, all features enabled by default)
# IMAGE_OPTIMIZATION_ENABLED=true    # Enable automatic image compression (default: true)
# IMAGE_CONVERT_TO_WEBP=true         # Convert images to WebP format (default: true)
# IMAGE_QUALITY=85                   # Compression quality 1-100 (default: 85)
# IMAGE_MAX_WIDTH=4096               # Max image width in pixels (default: 4096)
# IMAGE_MAX_HEIGHT=4096              # Max image height in pixels (default: 4096)

# CORS / front local
ALLOWED_ORIGINS=*,app://obsidian,http://localhost:4200,http://localhost:3000

# SEO: Base URL for sitemap and canonical URLs (local dev)
SITE_NAME=Obsidian VPS Publish
HOME_WELCOME_TITLE=Bienvenue sur Obsidian VPS Publish
BASE_URL=http://localhost:4200

# Infos non sensibles
AUTHOR=Jonathan Rouquette
REPO_URL=https://github.com/JoRouquette/obsidian-vps-publish
REPORT_ISSUES_URL=https://github.com/JoRouquette/obsidian-vps-publish/issues

# Secrets DEV (OK que ce soit moche, c’est pour ton PC)
JWT_SECRET=dev-only-not-secret
SESSION_SECRET=dev-only-not-secret
API_KEY=dev-api-key

# Nx configuration - Désactive l'UI interactive
NX_INTERACTIVE=false
CI=true
